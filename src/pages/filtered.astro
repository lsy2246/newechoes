---
import Layout from "@/components/Layout.astro";
import ArticleFilter from "@/components/ArticleFilter";
import { getCanonicalArticleUrl } from "@/lib/article-links";
import { resolveArticleIdentity } from "@/lib/article-history";
import { getPrebuiltArticleHistoryMap } from "@/lib/article-history/prebuilt.js";
import { getCollection, type CollectionEntry } from "astro:content";

export const prerender = true;

const searchParams = Astro.url.searchParams;
const articles: CollectionEntry<"articles">[] = await getCollection("articles");
const articleHistoryMap = await getPrebuiltArticleHistoryMap(articles);
const articleUpdatedAt = Object.fromEntries(
  articles.map((article) => {
    const articleIdentity = resolveArticleIdentity(article);
    const history = articleHistoryMap.get(articleIdentity);

    return [
      getCanonicalArticleUrl(article.id),
      (history?.updatedAt ?? article.data.date).toISOString(),
    ];
  }),
);
---

<Layout title="文章筛选" pageType="directory" description="文章筛选页面" skipSrTitle={false}>
  <ArticleFilter
    searchParams={searchParams}
    articleUpdatedAt={articleUpdatedAt}
    client:idle
  />
</Layout>
