---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/components/Layout.astro";
import { SOURCE_REPOSITORY_CONFIG } from "@/consts";
import { getCanonicalArticleUrl } from "@/lib/article-links";
import {
  assertUniqueArticleIdentities,
  formatArticleHistoryPath,
  resolveArticleIdentity,
} from "@/lib/article-history";
import {
  getArticleHistoryMap,
} from "@/lib/article-history";

export const prerender = true;

type ArticleEntry = CollectionEntry<"articles">;

const articles = (await getCollection("articles"))
  .filter((article: ArticleEntry) => !article.data.draft)
  .sort(
    (a: ArticleEntry, b: ArticleEntry) =>
      b.data.date.getTime() - a.data.date.getTime(),
  );
assertUniqueArticleIdentities(articles);

const articleHistoryMap = await getArticleHistoryMap(articles, SOURCE_REPOSITORY_CONFIG);

const monthNames = [
  "一月",
  "二月",
  "三月",
  "四月",
  "五月",
  "六月",
  "七月",
  "八月",
  "九月",
  "十月",
  "十一月",
  "十二月",
];

function getArticleUrl(article: ArticleEntry) {
  return getCanonicalArticleUrl(resolveArticleIdentity(article));
}

function getSummary(article: ArticleEntry) {
  if (article.data.summary) {
    return article.data.summary;
  }

  const plainText = article.body
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/!\[.*?\]\(.*?\)/g, " ")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[#*`~>]/g, "")
    .replace(/\s+/g, " ")
    .trim();

  return plainText.length > 84 ? `${plainText.slice(0, 84)}...` : plainText;
}

const grouped = new Map<string, Map<number, ArticleEntry[]>>();

for (const article of articles) {
  const year = String(article.data.date.getFullYear());
  const month = article.data.date.getMonth();

  if (!grouped.has(year)) {
    grouped.set(year, new Map());
  }

  const yearGroup = grouped.get(year)!;
  if (!yearGroup.has(month)) {
    yearGroup.set(month, []);
  }

  yearGroup.get(month)!.push(article);
}

const years = Array.from(grouped.keys());
const activeYear = years[0] || String(new Date().getFullYear());

const revisionEvents = articles
  .flatMap((article: ArticleEntry) => {
    const history = articleHistoryMap.get(resolveArticleIdentity(article));
    return (history?.revisions ?? []).map((revision: any) => ({
      ...revision,
      articleIdentity: resolveArticleIdentity(article),
      articleTitle: article.data.title,
      articleUrl: getArticleUrl(article),
    }));
  })
  .sort((a: any, b: any) => b.date.getTime() - a.date.getTime());

const revisionGroups = new Map<string, typeof revisionEvents>();
for (const event of revisionEvents) {
  const dayKey = event.date.toISOString().slice(0, 10);
  if (!revisionGroups.has(dayKey)) {
    revisionGroups.set(dayKey, []);
  }
  revisionGroups.get(dayKey)!.push(event);
}

const revisionCommitGroups = new Map<string, any[]>();
for (const [day, events] of revisionGroups) {
  const commitGroups = new Map<string, any>();

  for (const event of events) {
    const commitKey = event.hash || `${event.date.toISOString()}-${event.subject}`;
    if (!commitGroups.has(commitKey)) {
      commitGroups.set(commitKey, {
        hash: event.hash,
        shortHash: event.shortHash,
        date: event.date,
        subject: event.subject,
        kind: event.kind,
        commitUrl: event.commitUrl,
        events: [],
      });
    }

    const commit = commitGroups.get(commitKey);
    if (commit.kind !== "moved" && event.kind === "moved") {
      commit.kind = "moved";
    }
    commit.events.push(event);
  }

  revisionCommitGroups.set(day, Array.from(commitGroups.values()));
}

const revisionDays = Array.from(revisionGroups.keys());

function getYearCount(year: string) {
  return Array.from(grouped.get(year)!.values()).reduce(
    (total, monthArticles) => total + monthArticles.length,
    0,
  );
}

function formatRevisionDay(day: string) {
  return new Date(`${day}T00:00:00`).toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  });
}

function formatRevisionTime(date: Date) {
  return date.toLocaleTimeString("zh-CN", {
    hour: "2-digit",
    minute: "2-digit",
  });
}

function getRevisionLabel(kind: string) {
  if (kind === "moved") return "moved";
  return "updated";
}
---

<Layout
  title="文章时间线"
  pageType="directory"
  description="按发布时间浏览文章"
  skipSrTitle={false}
>
  <div class="article-index-shell">
    <section class="timeline-layout" aria-label="文章时间线">
      <input
        id="timeline-view-published"
        class="timeline-view-radio"
        type="radio"
        name="timeline-view"
        checked
      />
      <input
        id="timeline-view-revisions"
        class="timeline-view-radio"
        type="radio"
        name="timeline-view"
      />
      <div class="timeline-view-switch" aria-label="时间轴视图">
        <label for="timeline-view-published" data-timeline-view="published">发布时间轴</label>
        <span aria-hidden="true">/</span>
        <label for="timeline-view-revisions" data-timeline-view="revisions">修订记录</label>
      </div>

      <nav
        class="year-index timeline-year-index timeline-year-strip"
        aria-label="年份索引"
      >
        <span class="timeline-strip-label">年份</span>
        <div class="timeline-year-links">
          {years.map((year) => (
            <a
              class={year === activeYear ? "active" : ""}
              href={`#year-${year}`}
              aria-current={year === activeYear ? "true" : undefined}
              data-timeline-year-link={year}
            >
              <span>{year}</span>
              <small>{getYearCount(year)}</small>
            </a>
          ))}
        </div>
      </nav>

      <div class="timeline-panels">
        <div id="published" class="timeline-main timeline-river timeline-panel-published">
          {years.map((year) => {
            const months = Array.from(grouped.get(year)!.keys()).sort((a, b) => b - a);

            return (
              <section
                id={`year-${year}`}
                class="timeline-year-section"
                data-timeline-year-section={year}
                aria-label={`${year} 年文章`}
              >
                <div class="timeline-year-heading">
                  <p>{year}</p>
                  <span>{getYearCount(year)} 篇记录</span>
                </div>

                {months.map((month) => (
                  <div class="month-group">
                    <div class="month-label">
                      <span>{monthNames[month]}</span>
                      <small>
                        {grouped.get(year)!.get(month)!.length} 篇
                      </small>
                    </div>
                    <div class="timeline-list">
                      {grouped.get(year)!.get(month)!.map((article) => (
                        <a
                          class="timeline-item"
                          href={getArticleUrl(article)}
                          data-astro-prefetch="viewport"
                        >
                          <svg
                            class="timeline-icon"
                            viewBox="0 0 40 44"
                            fill="none"
                            aria-hidden="true"
                          >
                            <path d="M9 4h15l7 7v29H9V4Z" stroke="currentColor" stroke-width="1.5" />
                            <path d="M24 4v8h7" stroke="currentColor" stroke-width="1.5" />
                            <path d="M14 20h12M14 26h12M14 32h7" stroke="currentColor" stroke-width="1.5" />
                          </svg>
                          <span class="timeline-copy">
                            <strong>{article.data.title}</strong>
                            <span>{getSummary(article)}</span>
                          </span>
                          <time
                            class="timeline-date"
                            datetime={article.data.date.toISOString()}
                          >
                            <span>
                              {article.data.date.toLocaleDateString("zh-CN", {
                                month: "2-digit",
                                day: "2-digit",
                              })}
                            </span>
                          </time>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </section>
            );
          })}
        </div>

        <div id="revisions" class="timeline-revision-panel timeline-panel-revisions">
          {revisionDays.length > 0 ? (
            revisionDays.map((day) => (
              <section class="revision-day-group" aria-label={`${formatRevisionDay(day)} 修订`}>
                <div class="revision-day-label">
                  <span>{formatRevisionDay(day)}</span>
                  <small>
                    {revisionCommitGroups.get(day)!.length} 次提交 · {revisionGroups.get(day)!.length} 篇修订
                  </small>
                </div>
                <ol class="revision-list">
                  {revisionCommitGroups.get(day)!.map((commit: any) => (
                    <li class="revision-commit-group">
                      <div class="revision-commit-head">
                        <div class="revision-commit-meta">
                          <time datetime={commit.date.toISOString()}>
                            {formatRevisionTime(commit.date)}
                          </time>
                          {
                            commit.commitUrl ? (
                              <a
                                class="revision-hash"
                                href={commit.commitUrl}
                                target="_blank"
                                rel="noreferrer"
                              >
                                {commit.shortHash}
                              </a>
                            ) : (
                              <span class="revision-hash">{commit.shortHash}</span>
                            )
                          }
                          <span class:list={["revision-commit-kind", `is-${commit.kind}`]}>
                            {getRevisionLabel(commit.kind)}
                          </span>
                          <span class="revision-commit-subject">{commit.subject}</span>
                        </div>
                        <span class="revision-commit-count">{commit.events.length}</span>
                      </div>
                      <ol class="revision-article-list">
                        {commit.events.map((event: any) => (
                          <li class:list={["revision-article-item", `is-${event.kind}`]}>
                            <a
                              class="revision-copy"
                              href={event.articleUrl}
                              data-astro-prefetch="viewport"
                            >
                              <strong>{event.articleTitle}</strong>
                              <span>{getRevisionLabel(event.kind)}</span>
                              {
                                event.kind === "moved" && event.previousPath && event.currentPath && (
                                  <small>
                                    {formatArticleHistoryPath(event.previousPath)} → {formatArticleHistoryPath(event.currentPath)}
                                  </small>
                                )
                              }
                            </a>
                            <span class="revision-article-actions">
                              {
                                event.snapshotUrl && (
                                  <a
                                    href={event.snapshotUrl}
                                    target="_blank"
                                    rel="noreferrer"
                                  >
                                    历史快照
                                  </a>
                                )
                              }
                            </span>
                          </li>
                        ))}
                      </ol>
                    </li>
                  ))}
                </ol>
              </section>
            ))
          ) : (
            <div class="article-index-empty">
              <h3>暂无修订记录</h3>
              <p>当前构建环境没有可读取的 Git 历史。</p>
            </div>
          )}
        </div>
      </div>
    </section>
  </div>
</Layout>
