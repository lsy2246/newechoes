---
import Layout from "@/components/Layout.astro";
import NotFoundIllustration from "@/components/NotFoundIllustration.astro";

export const prerender = true;
---

<Layout
  title={`404 - 页面未找到`}
  description={`您访问的页面不存在或已被移动到其他位置`}
  hideFooter={true}
>
  <section
    class="not-found-shell"
    aria-labelledby="not-found-title"
  >
    <div class="not-found-figure">
      <NotFoundIllustration />
    </div>

    <div class="not-found-content">
      <h1
        id="not-found-title"
        class="not-found-title"
      >
        404 Not Found
      </h1>
      <p class="not-found-copy">
        你要找的页面不存在，或者已经被移动到别的地方。
      </p>
      <a
        href="/"
        class="not-found-action"
      >
        返回首页
      </a>
    </div>
  </section>
</Layout>
