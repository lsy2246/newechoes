---
import { formatArticleHistoryPath } from "@/lib/article-history";

type ArticleHistoryEvent = {
  kind: string;
  shortHash: string;
  subject: string;
  date: Date;
  commitUrl?: string;
  snapshotUrl?: string;
  previousPath?: string;
  currentPath?: string;
};

type Props = {
  events: ArticleHistoryEvent[];
};

const { events } = Astro.props as Props;

function formatRevisionDate(date: Date) {
  return date.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  });
}

function getRevisionLabel(kind: string) {
  if (kind === "moved") return "moved";
  if (kind === "published") return "published";
  return "updated";
}
---

<section class="article-history" aria-label="文章修订历史">
  <div class="article-history-head">
    <h2>历史版本</h2>
  </div>
  <ol class="article-history-list">
    {events.map((event) => (
      <li class:list={["article-history-item", `is-${event.kind}`]}>
        <span class="article-history-rail" aria-hidden="true"></span>
        <span class="article-history-version">
          {
            event.commitUrl ? (
              <a
                class="article-history-hash"
                href={event.commitUrl}
                target="_blank"
                rel="noreferrer"
              >
                {event.shortHash}
              </a>
            ) : (
              <span class="article-history-hash">{event.shortHash}</span>
            )
          }
          {
            event.snapshotUrl && (
              <a
                class="article-history-snapshot"
                href={event.snapshotUrl}
                target="_blank"
                rel="noreferrer"
              >
                历史快照
              </a>
            )
          }
        </span>
        <span class="article-history-copy">
          <strong>{getRevisionLabel(event.kind)}</strong>
          <span>{event.subject}</span>
          {
            event.kind === "moved" && event.previousPath && event.currentPath && (
              <small>
                {formatArticleHistoryPath(event.previousPath)} → {formatArticleHistoryPath(event.currentPath)}
              </small>
            )
          }
        </span>
        <time datetime={event.date.toISOString()}>
          {formatRevisionDate(event.date)}
        </time>
      </li>
    ))}
  </ol>
</section>
