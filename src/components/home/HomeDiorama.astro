---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { HOME_PROFILE } from "@/consts";
import "./diorama.css";

const articles = await getCollection("articles", ({ data }: CollectionEntry<"articles">) => !data.draft);
const postCount = articles.length;
const years = (() => {
  const dates = articles
    .map((a: CollectionEntry<"articles">) => a.data.date)
    .filter(Boolean)
    .map((d: Date | string) => new Date(d));
  if (!dates.length) return 1;
  const minYear = Math.min(...dates.map((d: Date) => d.getFullYear()));
  return Math.max(1, new Date().getFullYear() - minYear + 1);
})();
const autoPostsLabel = `${postCount} 篇 · 近 ${years} 年`;

---

<section class="home-diorama-shell" data-home-shell>
  <div class="home-diorama-stage" data-home-stage>
    <div class="home-diorama" data-home-scene aria-label="interactive 3D diorama homepage">
      <canvas class="home-diorama__canvas" data-diorama-canvas aria-hidden="true"></canvas>

      <div class="home-diorama__veil" aria-hidden="true"></div>

      <div class="screen-portal" data-screen-portal aria-hidden="true">
        <div class="screen-portal__surface" data-screen-portal-surface>
          <div class="screen-portal__stage">
            <div class="portal-page">
              <div class="portal-page__wash"></div>
              <div class="portal-page__grid"></div>

              <div class="portal-page__eyebrow">echoes / focus map</div>

              <div class="portal-page__hero">
                <h1>{HOME_PROFILE.title}</h1>
                <p>{HOME_PROFILE.subtitle}</p>
              </div>

              <div class="portal-chip portal-chip--accent" style="left: 140px; top: 288px;">inside the page</div>
              <div class="portal-chip" style="left: 332px; top: 288px;">scroll to pull back</div>
              <div class="portal-chip" style="left: 580px; top: 288px;">notes / projects / reading</div>
              <div class="portal-chip" style="left: 970px; top: 288px;">room appears later</div>

              <div class="portal-note portal-note--stack" style="left: 126px; top: 360px;">
                <span>stack</span>
                <strong>Rust · TypeScript</strong>
              </div>

              <div class="portal-note portal-note--signal portal-note--accent" style="left: 470px; top: 350px;">
                <span>signal</span>
                <strong>page folds into room</strong>
              </div>

              <div class="portal-note portal-note--contact" style="left: 982px; top: 138px;">
                <span>contact</span>
                <strong>{HOME_PROFILE.rows.find((row) => row.label === "contact")?.value ?? "lsy22@vip.qq.com"}</strong>
              </div>

              <div class="portal-note portal-note--articles" style="left: 1006px; top: 338px;">
                <span>articles</span>
                <strong>{autoPostsLabel}</strong>
              </div>

              <div class="portal-note portal-note--now portal-note--accent" style="left: 1120px; top: 538px;">
                <span>now</span>
                <strong data-portal-now>北京时间加载中</strong>
              </div>

              <div class="portal-thread">
                <span>current thread</span>
                <strong>&gt; {HOME_PROFILE.typewriter[0] ?? "now building"}</strong>
              </div>

              <div class="portal-page__line portal-page__line--a"></div>
              <div class="portal-page__line portal-page__line--b"></div>
              <div class="portal-page__line portal-page__line--c"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="home-diorama__hud">
        <div class="home-scroll-cue" data-home-scroll-cue aria-hidden="true">
          <span class="home-scroll-cue__label">向下滚动</span>
          <span class="home-scroll-cue__title">镜头会退出屏幕视角，露出 3D 房间</span>
          <span class="home-scroll-cue__line"></span>
        </div>
      </div>

      <div class="diorama-sr-nav" aria-label="quick navigation">
        <a href="/articles" data-astro-prefetch="hover">文章</a>
        <a href="/projects" data-astro-prefetch="hover">项目</a>
        <a href="/about" data-astro-prefetch="hover">关于</a>
        <a href="/books" data-astro-prefetch="hover">读书</a>
        <a href="/movies" data-astro-prefetch="hover">观影</a>
      </div>

      <div class="diorama-tooltip" data-diorama-tooltip aria-hidden="true"></div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ autoPostsLabel }}>
  window.__HOME_POSTS_LABEL = autoPostsLabel;
</script>

<script>
  import { initDiorama } from "./diorama";

  const isHome = () => {
    const p = window.location.pathname;
    return p === "/" || p === "";
  };

  const maybeInit = () => {
    if (isHome()) initDiorama();
  };

  maybeInit();
  document.addEventListener("astro:page-load", maybeInit);
  document.addEventListener("swup:contentReplaced", maybeInit);
  document.addEventListener("swup:page:view", maybeInit);
</script>
