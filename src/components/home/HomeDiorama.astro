---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import "./diorama.css";

const articles = await getCollection("articles", ({ data }: CollectionEntry<"articles">) => !data.draft);
const postCount = articles.length;
const years = (() => {
  const dates = articles
    .map((article: CollectionEntry<"articles">) => article.data.date)
    .filter(Boolean)
    .map((date: Date | string) => new Date(date));
  if (!dates.length) return 1;
  const minYear = Math.min(...dates.map((date: Date) => date.getFullYear()));
  return Math.max(1, new Date().getFullYear() - minYear + 1);
})();

const autoPostsLabel = `${postCount} 篇 · 近 ${years} 年`;
---

<section class="home-diorama-shell" data-home-shell>
  <div class="home-diorama-stage" data-home-stage>
    <div class="home-diorama" data-home-scene aria-label="interactive 3D diorama homepage">
      <canvas class="home-diorama__canvas" data-diorama-canvas aria-hidden="true"></canvas>
      <div class="home-story" data-home-story aria-hidden="true">
        <canvas class="home-story__canvas" data-story-canvas></canvas>
      </div>
      <div class="home-diorama__veil" aria-hidden="true"></div>
      <div class="home-diorama__loading" data-home-loading aria-live="polite">
        <div class="home-diorama__loading-spinner" aria-hidden="true"></div>
        <p class="home-diorama__loading-title">首页场景加载中</p>
        <p class="home-diorama__loading-detail" data-home-loading-detail>正在准备 3D 模型与字体...</p>
      </div>

      <div class="diorama-sr-nav" aria-label="quick navigation">
        <a href="/articles" data-astro-prefetch="hover">文章</a>
        <a href="/projects" data-astro-prefetch="hover">项目</a>
        <a href="/about" data-astro-prefetch="hover">关于</a>
        <a href="/books" data-astro-prefetch="hover">读书</a>
        <a href="/movies" data-astro-prefetch="hover">观影</a>
      </div>

      <div class="home-scroll-cue" data-home-scroll-cue data-home-visible="false" data-cue-mode="loading" aria-hidden="true">
        <div class="home-scroll-cue__motion">
          <span class="home-scroll-cue__motion-icon home-scroll-cue__motion-icon--scroll">
            <svg class="home-scroll-cue__mouse" viewBox="0 0 24 32" role="img">
              <rect x="7" y="3" width="10" height="18" rx="5"></rect>
              <path class="home-scroll-cue__wheel" d="M12 7.5v4.5"></path>
            </svg>
          </span>
          <span class="home-scroll-cue__motion-icon home-scroll-cue__motion-icon--drag">
            <svg class="home-scroll-cue__drag" viewBox="0 0 32 18" role="img">
              <path d="M5 9h22"></path>
              <path d="m10 4-5 5 5 5"></path>
              <path d="m22 4 5 5-5 5"></path>
            </svg>
          </span>
        </div>
        <div class="home-scroll-cue__progress"><span></span></div>
        <span class="home-scroll-cue__percent" data-home-cue-percent>0%</span>
      </div>

      <div class="diorama-tooltip" data-diorama-tooltip aria-hidden="true"></div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ autoPostsLabel }}>
  window.__HOME_POSTS_LABEL = autoPostsLabel;
</script>

<script>
  import {
    installHomeDioramaRehydrationBridge,
    mountHomeDioramaBoot,
  } from "./homeDioramaBoot.js";

  mountHomeDioramaBoot();
  installHomeDioramaRehydrationBridge();
</script>
