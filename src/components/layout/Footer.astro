---
import { SITE_META } from "@/consts";
import * as siteConfig from "@/consts";

interface Props {
  isHidden?: boolean;
}

const { isHidden = false } = Astro.props;

const currentYear = new Date().getFullYear();
const DEFAULT_FEATURE_FLAGS = {
  rss: true,
  sitemap: true,
};
type OptionalSiteConfig = typeof siteConfig & {
  FEATURE_FLAGS?: Partial<typeof DEFAULT_FEATURE_FLAGS>;
};
const optionalSiteConfig = siteConfig as OptionalSiteConfig;
const siteFeatureFlags = {
  ...DEFAULT_FEATURE_FLAGS,
  ...(optionalSiteConfig.FEATURE_FLAGS ?? {}),
};
---

<footer
  data-layout-footer
  data-layout-footer-hidden={isHidden ? "true" : "false"}
  hidden={isHidden}
  aria-hidden={isHidden ? "true" : "false"}
  class:list={[
    "site-footer w-full py-6 px-4 mt-auto",
    {
      hidden: isHidden,
    },
  ]}
>
  <div
    class="max-w-7xl mx-auto flex flex-col items-center justify-center space-y-4"
  >
    <div
      class="site-footer__links text-sm font-light flex flex-wrap items-center justify-center gap-2"
    >
      <a href={SITE_META.url}>
        © {currentYear} {SITE_META.title}. All rights reserved.
      </a>
      {
        siteFeatureFlags.sitemap && (
          <>
            <span
              aria-hidden="true"
              class="hidden sm:inline"
              >·</span
            >
            <a
              href="/sitemap.xml"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="网站地图"
            >
              Sitemap
            </a>
          </>
        )
      }
      {
        siteFeatureFlags.rss && (
          <>
            <span
              aria-hidden="true"
              class="hidden sm:inline"
              >·</span
            >
            <a
              href="/rss.xml"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="RSS订阅"
            >
              RSS
            </a>
          </>
        )
      }
    </div>
  </div>
</footer>
