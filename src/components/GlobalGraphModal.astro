---
import { getCollection, type CollectionEntry } from "astro:content";
import { contentStructure, type ContentStructure, type SectionStructure } from "@/content.config";
import {
  createArticleReferenceResolver,
  extractArticleReferences,
  getArticleRouteVariants,
  getCanonicalArticleUrl,
} from "@/lib/article-links";

interface Props {
  articleId?: string;
  articleTitleMap?: Map<string, string>;
  contentStructure?: ContentStructure;
  currentArticleId?: string;
  currentPath?: string;
  currentSectionPath?: string;
  level?: number;
  renderAs?: "modal" | "tree";
  section?: SectionStructure;
}

type ArticleRecord = CollectionEntry<"articles">;

type GraphNode = {
  id: string;
  label: string;
  type: "root" | "section" | "article";
  route: string;
  sectionPath?: string;
  topSectionPath?: string;
};

type GraphLink = {
  source: string;
  target: string;
  kind: "structure" | "reference";
};

const {
  articleId,
  articleTitleMap: providedArticleTitleMap,
  contentStructure: providedContentStructure,
  currentArticleId: providedCurrentArticleId,
  currentPath = "/",
  currentSectionPath: providedCurrentSectionPath = "",
  level = 0,
  renderAs = "modal",
  section,
} = Astro.props;

const isTreeRender = renderAs === "tree";
const articles: ArticleRecord[] = isTreeRender ? [] : await getCollection("articles");

function normalizeRoute(path: string) {
  if (!path) return "/";
  return path === "/" ? "/" : path.replace(/\/$/, "");
}

function articleUrl(articleId: string) {
  return getCanonicalArticleUrl(articleId);
}

function sectionUrl(sectionPath: string) {
  return `/articles/${encodeURI(sectionPath)}`;
}

const normalizedCurrentPath = normalizeRoute(currentPath);

const articleTitleMap =
  providedArticleTitleMap ??
  new Map(articles.map((article) => [article.id, article.data.title]));

const currentArticle =
  isTreeRender
    ? null
    : articles.find((article) =>
        getArticleRouteVariants(article.id).includes(normalizedCurrentPath),
      ) ?? null;

const currentArticleId = isTreeRender ? providedCurrentArticleId : currentArticle?.id;
const currentSectionPath = isTreeRender
  ? providedCurrentSectionPath
  : currentArticle
    ? currentArticle.id.includes("/")
      ? currentArticle.id.slice(0, currentArticle.id.lastIndexOf("/"))
      : ""
    : normalizedCurrentPath.startsWith("/articles/")
      ? decodeURI(normalizedCurrentPath.replace(/^\/articles\//, ""))
      : "";

const structure = providedContentStructure ?? contentStructure;

function isSectionActive(sectionPath: string) {
  if (!sectionPath) return false;
  return (
    currentSectionPath === sectionPath ||
    currentSectionPath.startsWith(`${sectionPath}/`) ||
    (currentArticleId ? currentArticleId.startsWith(`${sectionPath}/`) : false)
  );
}

function getArticleTitle(articleId: string) {
  return articleTitleMap.get(articleId) ?? articleId.split("/").at(-1) ?? articleId;
}

const articleHref = articleId ? articleUrl(articleId) : "";
const articleTitle = articleId ? getArticleTitle(articleId) : "";
const isCurrent = currentArticleId === articleId;

const open = section ? isSectionActive(section.path) : false;
const isSectionCurrent = section
  ? currentSectionPath === section.path && !currentArticleId
  : false;
const sectionHref = section ? sectionUrl(section.path) : "";
const childCount = section ? section.articles.length + section.sections.length : 0;
const hasChildren = childCount > 0;

const graphNodes: GraphNode[] = [];
const graphLinks: GraphLink[] = [];

function collectSections(sections: SectionStructure[], parentPath = "") {
  sections.forEach((section) => {
    const topSectionPath = parentPath ? parentPath.split("/")[0] : section.path.split("/")[0] ?? "";
    const node: GraphNode = {
      id: `section:${section.path}`,
      label: section.name,
      type: "section",
      route: sectionUrl(section.path),
      sectionPath: section.path,
      topSectionPath,
    };
    graphNodes.push(node);

    graphLinks.push({
      source: parentPath ? `section:${parentPath}` : "root",
      target: node.id,
      kind: "structure",
    });

    collectSections(section.sections, section.path);
  });
}

if (!isTreeRender) {
  graphNodes.push({
    id: "root",
    label: "全部文章",
    type: "root",
    route: "/articles",
  });

  collectSections(contentStructure.sections);

  articles.forEach((article) => {
    const sectionPath = article.id.includes("/")
      ? article.id.slice(0, article.id.lastIndexOf("/"))
      : "";
    const topSectionPath = article.id.includes("/") ? article.id.split("/")[0] : "";

    graphNodes.push({
      id: `article:${article.id}`,
      label: article.data.title,
      type: "article",
      route: articleUrl(article.id),
      sectionPath,
      topSectionPath,
    });

    graphLinks.push({
      source: sectionPath ? `section:${sectionPath}` : "root",
      target: `article:${article.id}`,
      kind: "structure",
    });
  });

  const resolveArticleReference = createArticleReferenceResolver(
    articles.map((article) => article.id),
  );

  for (const sourceArticle of articles) {
    for (const targetArticle of articles) {
      if (sourceArticle.id === targetArticle.id) continue;
      if (
        extractArticleReferences(sourceArticle.body, resolveArticleReference).has(
          targetArticle.id,
        )
      ) {
        graphLinks.push({
          source: `article:${sourceArticle.id}`,
          target: `article:${targetArticle.id}`,
          kind: "reference",
        });
      }
    }
  }
}

const graphPayload = JSON.stringify({
  nodes: graphNodes,
  links: graphLinks,
});
---

{
  isTreeRender ? (
    articleId ? (
      <li
        class="graph-tree-item graph-tree-item-article"
        data-article-id={articleId}
        style={`--tree-level:${level};`}
      >
        <a
          href={articleHref}
          class:list={[
            "graph-tree-link",
            "graph-tree-link-article",
            { "is-current": isCurrent },
          ]}
          data-route-target={articleHref}
          data-node-target={`article:${articleId}`}
          data-astro-prefetch="hover"
        >
          <span class="graph-tree-label">{articleTitle}</span>
        </a>
      </li>
    ) : section ? (
      <li
        class="graph-tree-item graph-tree-item-section"
        data-section-path={section.path}
        style={`--tree-level:${level};`}
      >
        <div
          class:list={["graph-tree-group", { "is-open": open }]}
          data-section-path={section.path}
          data-open={open ? "true" : "false"}
        >
          <button
            type="button"
            class="graph-tree-summary"
            aria-label={`展开或折叠 ${section.name}`}
            aria-expanded={open ? "true" : "false"}
            data-tree-disclosure
          >
            <span
              class="graph-tree-disclosure"
              aria-hidden="true"
            >
              <svg
                viewBox="0 0 12 12"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m4 2 4 4-4 4"></path>
              </svg>
            </span>
          </button>

          <a
            href={sectionHref}
            class:list={[
              "graph-tree-link",
              "graph-tree-link-section",
              { "is-current": isSectionCurrent },
            ]}
            data-route-target={sectionHref}
            data-section-path={section.path}
            data-node-target={`section:${section.path}`}
            data-astro-prefetch="hover"
          >
            <span class="graph-tree-label">{section.name}</span>
          </a>

          <span class="graph-tree-count">{childCount}</span>

          {
            hasChildren ? (
              <ul class="graph-tree-children" hidden={!open}>
                {
                  section.sections.map((child) => (
                    <Astro.self
                      renderAs="tree"
                      articleTitleMap={articleTitleMap}
                      currentArticleId={currentArticleId}
                      currentSectionPath={currentSectionPath}
                      level={level + 1}
                      section={child}
                    />
                  ))
                }
                {
                  section.articles.map((childArticleId) => (
                    <Astro.self
                      renderAs="tree"
                      articleId={childArticleId}
                      articleTitleMap={articleTitleMap}
                      currentArticleId={currentArticleId}
                      currentSectionPath={currentSectionPath}
                      level={level + 1}
                    />
                  ))
                }
              </ul>
            ) : (
              <div class="graph-tree-empty" hidden={!open}>这个目录下暂时没有更多分支</div>
            )
          }
        </div>
      </li>
    ) : (
      <ul class="global-graph-tree">
        {
          structure.articles.length > 0 && (
            <li class="graph-tree-item graph-tree-item-top">
              <div class="graph-tree-top-label">根目录文章</div>
              <ul class="graph-tree-children">
                {
                  structure.articles.map((rootArticleId) => (
                    <Astro.self
                      renderAs="tree"
                      articleId={rootArticleId}
                      articleTitleMap={articleTitleMap}
                      currentArticleId={currentArticleId}
                      currentSectionPath={currentSectionPath}
                      level={0}
                    />
                  ))
                }
              </ul>
            </li>
          )
        }

        {
          structure.sections.map((rootSection) => (
            <Astro.self
              renderAs="tree"
              articleTitleMap={articleTitleMap}
              currentArticleId={currentArticleId}
              currentSectionPath={currentSectionPath}
              section={rootSection}
            />
          ))
        }
      </ul>
    )
  ) : (
    <div
      id="global-graph-modal"
      class="global-graph-modal hidden"
      aria-hidden="true"
    >
      <script
        type="application/json"
        data-global-graph-json
        set:html={graphPayload}
      ></script>

      <div
        class="global-graph-backdrop"
        data-close-global-graph
      ></div>

      <section
        class="global-graph-dialog"
        role="dialog"
        aria-modal="true"
        aria-labelledby="global-graph-title"
      >
        <header class="global-graph-header">
          <div>
            <p class="global-graph-eyebrow">Site Index</p>
            <h2 id="global-graph-title">全站索引点群</h2>
            <p class="global-graph-subtitle">
              左边按文件树精确定位，右边用会轻微游动的点呈现文章关系。拖动节点时，相邻节点会被轻轻带动。
            </p>
          </div>
          <button
            type="button"
            class="global-graph-close"
            data-close-global-graph
            aria-label="关闭全局图谱"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </header>

        <div class="global-graph-body global-graph-body-split">
          <aside class="global-graph-tree-panel">
            <div class="global-graph-panel-header">
              <div>
                <h3>文字索引</h3>
              </div>
            </div>

            <div class="global-graph-tree-shell">
              <Astro.self
                renderAs="tree"
                articleTitleMap={articleTitleMap}
                contentStructure={contentStructure}
                currentArticleId={currentArticle?.id}
                currentSectionPath={currentSectionPath}
              />
            </div>
          </aside>

          <section class="global-graph-stage">
            <div class="global-graph-panel-header">
              <div>
                <h3>2D 点群</h3>
                <p>拖动画布浏览关系，拖动节点微调位置，点击节点进入文章。</p>
              </div>
              <span class="global-graph-drag-hint">Drag / Zoom</span>
            </div>

            <div
              class="global-graph-stage-canvas"
              data-graph-stage
            >
              <div
                class="global-graph-canvas"
                data-graph-canvas
              ></div>
              <div
                class="global-graph-status"
                data-graph-status
              >
              正在准备 2D 点群...
              </div>
              <div
                class="global-graph-tooltip"
                data-graph-tooltip
                hidden
              ></div>
            </div>
          </section>
        </div>
      </section>
    </div>
  )
}

{
  !isTreeRender && (
    <script>
      import { initGlobalGraphModal } from "@/lib/global-graph-modal";

      initGlobalGraphModal();
    </script>
  )
}
