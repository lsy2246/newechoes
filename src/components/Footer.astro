---
interface Props {
  isHidden?: boolean;
}

const { isHidden = false } = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer
  data-layout-footer
  data-layout-footer-hidden={isHidden ? "true" : "false"}
  hidden={isHidden}
  aria-hidden={isHidden ? "true" : "false"}
  class:list={[
    "site-footer w-full py-6 px-4 mt-auto",
    {
      "hidden": isHidden,
    },
  ]}
>
  <div
    class="max-w-7xl mx-auto flex flex-col items-center justify-center space-y-4"
  >
    <div
      class="site-footer__links text-sm font-light flex flex-wrap items-center justify-center gap-2"
    >
      <a
        href="https://blog.lsy22.com"
      >
        © {currentYear} New Echoes. All rights reserved.
      </a>
      <span
        aria-hidden="true"
        class="hidden sm:inline"
        >·</span
      >
      <a
        href="/sitemap.xml"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="网站地图"
      >
        Sitemap
      </a>
      <span
        aria-hidden="true"
        class="hidden sm:inline"
        >·</span
      >
      <a
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="RSS订阅"
      >
        RSS
      </a>
    </div>
  </div>
</footer>
