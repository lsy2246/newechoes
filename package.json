{
  "name": "newechoes",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "generate:function-wrappers": "node scripts/generate-function-wrappers.mjs",
    "generate:function-wrappers:vercel": "node scripts/generate-function-wrappers.mjs vercel",
    "generate:function-wrappers:cloudflare": "node scripts/generate-function-wrappers.mjs cloudflare",
    "generate:function-wrappers:edgeone": "node scripts/generate-function-wrappers.mjs edgeone",
    "build": "bun run generate:function-wrappers && node --experimental-strip-types scripts/astro-build.mjs",
    "build:vercel": "bun run generate:function-wrappers:vercel && node --experimental-strip-types scripts/astro-build.mjs vercel",
    "build:edgeone": "bun run generate:function-wrappers:edgeone && node --experimental-strip-types scripts/astro-build.mjs edgeone",
    "build:cloudflare": "bun run generate:function-wrappers:cloudflare && node --experimental-strip-types scripts/astro-build.mjs cloudflare",
    "deploy:cloudflare": "bun run generate:function-wrappers:cloudflare && wrangler pages deploy dist",
    "preview": "astro preview",
    "astro": "astro",
    "newpost": "node src/plugins/new-post.mjs",
    "test": "bun run generate:function-wrappers && node --experimental-strip-types --test --test-concurrency=1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/node": "^10.1.1",
    "@astrojs/react": "^5.0.5",
    "@astrojs/vercel": "^10.0.7",
    "@edgeone/astro": "^1.1.2",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@swup/fragment-plugin": "^1.3.0",
    "@swup/head-plugin": "^2.3.1",
    "@swup/preload-plugin": "^3.2.11",
    "@swup/progress-plugin": "^3.2.0",
    "@swup/scripts-plugin": "^2.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/three": "^0.184.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.3.7",
    "astro-mermaid": "^2.0.1",
    "cheerio": "^1.2.0",
    "d3-force-3d": "^3.0.6",
    "mermaid": "^11.15.0",
    "octokit": "^5.0.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-masonry-css": "^1.0.16",
    "swup": "^4.9.0",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "binaryen": "129.0.0",
    "playwright": "^1.60.0",
    "rehype-external-links": "^3.0.0",
    "wrangler": "^4.96.0"
  }
}
